# Frontend environment (Vite). Copy this file to `.env` and adjust values.
# Restart `npm run dev` after any change.
#
# Sign in / sign up call the backend (`/api/auth/*`). The app stores a JWT in localStorage after login.

# Backend origin only (no `/api` suffix). Used for:
# - Dev: Vite proxy forwards same-origin `/api/*` to `${API_PROXY_TARGET}/api/*`
# - Production build: client uses `${API_PROXY_TARGET}/api` as the fetch base
#
# Local backend:
#   API_PROXY_TARGET=http://localhost:4100
#
# Deployed backend (example):
#   API_PROXY_TARGET=https://api.example.com
#   API_PROXY_TARGET=https://api.example.com/digitalmarketing
#
# Vercel / CI: your local `.env` is NOT used on the build machine (and is usually gitignored).
# Add the SAME variable in: Project → Settings → Environment Variables → API_PROXY_TARGET
# (Production + Preview). Then redeploy so the bundle embeds https://your-api.../api, not /api.
# Optional alias: VITE_API_PROXY_TARGET (same value).
#
API_PROXY_TARGET=http://localhost:4100
