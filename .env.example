# Frontend environment (Vite). Copy this file to `.env` and adjust values.
# Restart `npm run dev` after any change.
#
# Sign in / sign up call the backend (`/api/auth/*`). Run the API locally or point
# VITE_API_URL at your deployed API. The app stores a JWT in localStorage after login.

# API base URL — must include `/api` at the end (paths in code are like `/content/categories`).
# Use the same base URL your backend shows when it starts (host + port + /api).
#
# Local dev (recommended): Vite proxy — same origin, no CORS. Set BOTH:
#   VITE_API_URL=/api
#   API_PROXY_TARGET=http://localhost:4100
# (Replace host/port with whatever your backend prints, e.g. http://127.0.0.1:4100)
#
# Direct to backend (set backend `CORS_ORIGIN` to this Vite origin). Only VITE_API_URL needed:
#   VITE_API_URL=http://localhost:4100/api
#
# Deployed / staging:
#   VITE_API_URL=https://your-api.example.com/api
#
VITE_API_URL=/api
API_PROXY_TARGET=http://localhost:4100
